{
"layer": "top",
"position": "top",
"height": 30,
"margin-bottom":0,
"margin-top":0,

"modules-left": ["cpu","memory","network","disk","mpd"],
"modules-center": ["hyprland/workspaces"],
"modules-right":  ["tray","idle_inhibitor","pulseaudio","backlight","battery","clock"],

"battery": {
